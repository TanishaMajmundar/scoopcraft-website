{
  "info": {
    "name": "Mithas Ice Cream API",
    "description": "Full API collection for Mithas Indian Ice Cream Store",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+91 98765 43210\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products" }
        },
        {
          "name": "Get Products by Category",
          "request": { "method": "GET", "url": "{{baseUrl}}/products?category=kulfi" }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products?search=mango" }
        },
        {
          "name": "Get Single Product",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/1" }
        },
        {
          "name": "Create Product (with image)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Gulab Jamun Ice Cream" },
                { "key": "description", "value": "Classic gulab jamun mixed into velvety ice cream" },
                { "key": "price", "value": "119" },
                { "key": "category", "value": "sundae" },
                { "key": "emoji", "value": "🍮" },
                { "key": "rating", "value": "4.7" },
                { "key": "reviews", "value": "89" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"id\": \"1\", \"name\": \"Kesar Pista Kulfi\", \"price\": 89, \"qty\": 2, \"emoji\": \"🌟\" }\n  ],\n  \"address\": {\n    \"name\": \"Priya Sharma\",\n    \"phone\": \"+91 98765 43210\",\n    \"line1\": \"Flat 4B, Sunshine Apartments\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"pincode\": \"400001\"\n  },\n  \"paymentMethod\": \"upi\",\n  \"totalAmount\": 227\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        {
          "name": "Initiate UPI",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payment/upi/initiate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD123456\",\n  \"amount\": 227,\n  \"upiId\": \"priya@paytm\"\n}"
            }
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payment/verify",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionRef\": \"MITHASABC123\",\n  \"orderId\": \"ORD123456\"\n}"
            }
          }
        },
        {
          "name": "Confirm COD",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payment/cod/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD123456\"\n}"
            }
          }
        }
      ]
    }
  ]
}
